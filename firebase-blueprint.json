{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Authorized admin users for managed access area",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["admin"]
        }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": {
        "$ref": "#/entities/Admin"
      },
      "description": "Admins"
    }
  }
}
